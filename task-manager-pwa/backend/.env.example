# Server
PORT=5000

# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/taskmanager?retryWrites=true&w=majority

# JWT Secrets
JWT_ACCESS_SECRET=your_access_secret_here_change_me
JWT_REFRESH_SECRET=your_refresh_secret_here_change_me

# SMTP (use Mailtrap or Ethereal for testing)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass

# Frontend URL (for CORS & email links)
CLIENT_URL=http://localhost:5173
